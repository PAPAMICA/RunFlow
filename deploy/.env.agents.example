# RunFlow — agent worker (machine distante)
# Copier vers .env sur chaque serveur agent

# URL publique de l'API RunFlow (HTTPS)
RUNFLOW_API_URL=https://api.runflow.example.com

# Token obtenu via : runflow-worker register --server ... --registration-token ...
RUNFLOW_WORKER_TOKEN=

# Nom unique par agent (utilisé pour le container_name)
WORKER_NAME=agent-geneva

# Images runner (construites localement via deploy/build-runners.sh)
PYTHON_RUNNER_IMAGE=runflow/runner-python:0.1.0
BASH_RUNNER_IMAGE=runflow/runner-bash:0.1.0
ANSIBLE_RUNNER_IMAGE=runflow/runner-ansible:0.1.0

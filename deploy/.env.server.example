# RunFlow — déploiement serveur (Traefik)
# Copier vers .env à la racine du dépôt : cp deploy/.env.server.example .env

# --- Domaines (Traefik) ---
RUNFLOW_WEB_HOST=runflow.example.com
RUNFLOW_API_HOST=api.runflow.example.com

# --- Sécurité ---
JWT_SECRET=change-me-to-a-random-secret-in-production
RUNFLOW_MASTER_KEY=change-me-32-bytes-minimum

# CORS : dérivé automatiquement de RUNFLOW_WEB_HOST par deploy-server.sh
CORS_ORIGINS=https://runflow.example.com

# URL API injectée au build Next.js (accessible depuis le navigateur)
NEXT_PUBLIC_API_URL=https://api.runflow.example.com

# --- Base de données ---
# Hôte = alias réseau du conteneur runflow_postgres (évite les conflits DNS)
POSTGRES_HOST=runflow_postgres
POSTGRES_USER=runflow
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=runflow

# --- Admin initial (créé par deploy/deploy-server.sh si absent) ---
RUNFLOW_ADMIN_EMAIL=admin@runflow.local
RUNFLOW_ADMIN_PASSWORD=

# --- Worker intégré au serveur ---
WORKER_NAME=server
RUNFLOW_WORKER_TOKEN=

# --- Réseau Traefik ---
TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=http

# RunFlow environment configuration (développement local — docker-compose.yml)
# Production : voir deploy/.env.server.example et deploy/.env.agents.example

# Database
DATABASE_URL=postgresql+asyncpg://runflow:runflow@postgres:5432/runflow

# Valkey
VALKEY_URL=redis://valkey:6379/0

# Security
JWT_SECRET=change-me-to-a-random-secret-in-production
# Required for secrets/credentials/AI encryption (32+ random bytes, base64 or hex)
RUNFLOW_MASTER_KEY=

# API
CORS_ORIGINS=http://localhost:3000
DATA_DIR=/data
JOBS_DIR=/data/jobs
RUNS_DIR=/data/runs

# Worker
RUNFLOW_API_URL=http://api:8000
RUNFLOW_WORKER_TOKEN=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Notifications sortantes (optionnel — email + Pushover)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
PUSHOVER_APP_TOKEN=

# Postgres (docker-compose)
POSTGRES_USER=runflow
POSTGRES_PASSWORD=runflow
POSTGRES_DB=runflow
